\begin{document}

\begin{tikzpicture}
\tikzstyle{vertex}=[black,circle,fill,minimum size=5,inner sep=0pt]
\begin{scope}[every node/.style={vertex}]
 \node (l) at (0,0) {};
 \node (x1) at (0.6,0.5) {};
 \node (y1) at (0.6,-0.5) {};
 \node (x2) at (0.6+2,0.5) {};
 \node (y2) at (0.6+2,-0.5) {};
 \node (x3) at (0.6+4,0.5) {};
 \node (y3) at (0.6+4,-0.5) {};
 \node (x4) at (0.6+6,0.5) {};
 \node (y4) at (0.6+6,-0.5) {};
 \node (r) at (1.2+6,0) {};
\end{scope}

\node at (0.6+3,0) {$a_i$};

\node[left] at (0,0) {$v_0$};
\node[above] at (0.6,0.5) {$v_1$};
\node[below] at (0.6,-0.5) {$v_k$};
\node[above] at (0.6+2,0.5) {$v_{i-1}$};
\node[below] at (0.6+2,-0.5) {$v_{k+2-i}$};
\node[above] at (0.6+4,0.5) {$v_i$};
\node[below] at (0.6+4,-0.5) {$v_{k+1-i}$};
\node[above] at (0.6+6,0.5) {$v_{m-1}$};
\node[below] at (0.6+6,-0.5) {$v_{m+1}$};
\node[right] at (1.2+6,0) {$v_m~( m=\frac{k+1}{2})$};
\draw[very thick,-] (l.east) to (x1.west);
\draw[very thick,dotted,-] (x1.east) to (x2.west);
\draw[very thick,-,blue] (x2.east) to (x3.west);
\draw[very thick,dotted,-] (x3.east) to (x4.west);
\draw[very thick,-] (x4.east) to (r.west);
\draw[very thick,-] (l.east) to (y1.west);
\draw[very thick,dotted,-] (y1.east) to (y2.west);
\draw[very thick,-,blue] (y2.east) to (y3.west);
\draw[very thick,dotted,-] (y3.east) to (y4.west);
\draw[very thick,-] (y4.east) to (r.west);
\end{tikzpicture}

