\usepackage{tikz}
\usepackage{pgfplots}
\pgfplotsset{compat=1.18}

\begin{document}

% https://tex.stackexchange.com/questions/100022
\pgfmathdeclarefunction{myGaussFcn}{3}{%
  \pgfmathparse{1/(#3*sqrt(2*pi))*exp(-((#1-#2)^2)/(2*#3^2))}%
}

\begin{tikzpicture}
    \begin{axis}[
            xlabel = {Daily change},
            ylabel = {Probability of Event},
        ]
        % Plot 1
        \addplot[
                ybar interval, 
                color = blue,
                opacity = 0.3,
                fill = blue
            ] table [
                    x = C,
                    y = V
                ]{sp500Dist.dat};
         % Plot 2
        \addplot[
                domain = -0.1:0.1,
                samples = 201,
            ] {0.002*myGaussFcn(x, 0, 0.017)};
    \end{axis}
\end{tikzpicture}

\end{document}