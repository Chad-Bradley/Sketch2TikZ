\onslide<1-10>{
\draw[flow=red] 
(0.1,1) --  ++(-1,0) -- ++(0,-3) -- ++(5,0) -- ++(0,1.5) --
  ++(3,0) -- ++(0,2) -- ++(-4,0) --  ++(0,2.5) -- ++(-0.8,0) -- ++(0,-4.3) -- 
