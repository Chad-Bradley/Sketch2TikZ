\begin{tikzpicture}

% Draw the butter
\fill[yellow!80!white] (0,0) ellipse (1.5 and 1);
\fill[brown!50!white] (-1.5,0) rectangle (1.5,-1);

% Draw the knife
\fill[gray!50!white] (-1.5,0) rectangle (-2,-3);
\fill[gray!50!white] (-2,-1.5) rectangle (0,-2);
\fill[gray!50!white] (-2,-3) rectangle (-1.5,-2);

% Draw the plate
\fill[white] (-3,-3) rectangle (3,-4);

\end{tikzpicture}

