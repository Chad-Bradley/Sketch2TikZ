\documentclass{article}

\usepackage{tikz} % Import TikZ package

\begin{document}

\begin{tikzpicture}[scale=0.5] % Create a TikZ picture environment with a scale of 0.5

% Draw the bamboo stem
\draw[thick, green!50!black] (0,0) -- (0,8);

% Draw the bamboo leaves
\foreach \y in {0.5,1.5,...,7.5} {
  \draw[thick, green!50!black] (-0.5,\y) -- (0,\y+0.5) -- (0.5,\y) -- cycle;
}

\end{tikzpicture}

\end{document}