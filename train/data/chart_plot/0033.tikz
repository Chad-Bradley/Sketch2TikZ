\draw (6, 0) -- (6.5, -0.5) .. controls (7.5,-1.5) .. (6+3,-1);
\draw[fill] (0, 0) circle (2pt) node[anchor=south]{$x$};
\draw[fill] (-0.5, -0.5) circle (2pt) node[anchor=south]{$a$};
\draw[fill] (0.5, -0.5) circle (2pt) node[anchor=south]{$b$};
