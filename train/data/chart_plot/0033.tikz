\draw[fill] (5.5, -0.5) circle (2pt) node[anchor=south]{$c$};
\draw[transparent] (3, -1.5) circle (2pt) node[anchor=south]{$Q$};
\draw[transparent] (-1.5, -0.5) circle (2pt) node[anchor=north]{$P$};
