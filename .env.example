# ====== API Keys ======
# ModelScope (Vision + Code models)
MODELSCOPE_API_KEY=your_modelscope_key_here
# SiliconFlow (alternative text models)
SILICONFLOW_API_KEY=your_siliconflow_key_here
# ZhipuAI (GLM series)
ZHIPU_API_KEY=your_zhipu_key_here

# ====== LaTeX Compiler ======
# Absolute path to xelatex executable
XELATEX_PATH=/path/to/xelatex

# ====== Ghostscript (optional, auto-detected from PATH) ======
# GS_PATH=/path/to/gs

# ====== Model Defaults ======
VISION_MODEL=Qwen/Qwen3-VL-235B-A22B-Instruct
CODE_MODEL=Qwen/Qwen3-Coder-480B-A35B-Instruct
